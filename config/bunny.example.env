# Copy to config/bunny.env only when gallery.json sets cdn.provider to "bunny".
# Never commit the real file.
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_PASSWORD=your-storage-zone-api-password
BUNNY_STORAGE_ENDPOINT=https://storage.bunnycdn.com
BUNNY_CDN_HOST=your-pull-zone.b-cdn.net
BUNNY_TOKEN_KEY=your-pull-zone-token-authentication-key
BUNNY_CORS_READY=0
