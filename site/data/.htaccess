Options -Indexes

RewriteEngine On
# Quality reports are version-keyed and expose only the generated, read-only
# artifacts expected by the authenticated gallery. dashboard.json is a small,
# presentation-only projection derived from report.json and the HLS playlist.
RewriteRule ^(?!quality/[0-9a-f]{18}--[0-9a-f]{14}/(?:dashboard\.json|report\.json|frames\.csv|report\.html)$)(?:.*/)?(?:dashboard\.json|report\.json|frames\.csv|report\.html)$ - [F,L,NC]

<IfModule mod_headers.c>
  Header always set Cache-Control "private, no-store, max-age=0"

  # The standalone report has one fixed inline controller and inert JSON data.
  # Permit only that exact controller so it remains interactive when served by
  # the gallery without weakening the application's normal script policy.
  <FilesMatch "^report\.html$">
    Header always set Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; form-action 'none'; script-src 'sha256-FeN/izVWLHz7Wxc0kzFGeJ+Meq3K6XeSq/wscwfK6MM='; style-src 'unsafe-inline'; img-src data:; connect-src 'none'; media-src 'none'; font-src 'none'"
  </FilesMatch>
</IfModule>

<FilesMatch "^(?!(catalog|encode-progress|content-index|content-analysis-progress|quality-cards|quality-analysis-progress|bunny-sync-status)\.json$|encode-preview\.jpg$|dashboard\.json$|report\.json$|frames\.csv$|report\.html$).+">
  Require all denied
</FilesMatch>
